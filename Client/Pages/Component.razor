@inject HttpClient Http
@using Shared.Models;
@using Common.Exception;
@using Common.Types;
@using Helpers;

<h3 id="titel">Unsere Produkte</h3>

@if (_produktListe == null) {
    <p><em>Daten werden vom Server geladen... Bitte warten.</em></p>
} else {
    <div class="produkt-grid">
        @if(_produktListe.IsSuccess){
            @foreach (var produkt in _produktListe.Data ?? []) {
                <div class="produkt-karte" @onclick="() => ShowDetailedInfo(produkt)">
                    <h4>@produkt.Name</h4>
                    <p>Preis: @produkt.Price CHF</p>
                    <button id="produkt-@produkt.Id" class="DeleteButton" @onclick="() => DeleteProduct(produkt)">Löschen</button>
                </div>
            }
        } else {
            <ErrorPopup IsVisible="true" ErrorMessage="@ErrorMessageMapper.ToUserMessage(_produktListe.ErrorCode)" />
        }

    </div>
}